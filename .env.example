JWT_SECRET=CHANGE_ME_long_random_string
PORT=8080
RESEND_API_KEY=re_CHANGE_ME
BASE_URL=https://yourdomain.com

# Frontend
PUBLIC_API_URL=https://yourdomain.com
PUBLIC_WS_URL=wss://yourdomain.com
